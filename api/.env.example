# Application
PORT=9089
APP_NAME=Bulk Data Wholesale
NODE_ENV=development
API_HTTPS_ENABLED=false

# URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:9089
BACKEND_URL=http://localhost:9089
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://example.com

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=kimbowa
DB_NAME=bulk-data

DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_SSL=false
DB_POOL_SIZE=10

# Redis (required for rate limiting, sessions, risk context)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_DEFAULT=3600

# JWT (access + refresh tokens)
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-strong-secret
JWT_REFRESH_EXPIRES_IN=7d

# Authentication Policy
AUTH_MAX_ACTIVE_SESSIONS=3
AUTH_REQUIRE_VERIFIED_EMAIL_LOCAL=true
AUTH_REQUIRE_VERIFIED_EMAIL_SOCIAL=false
AUTH_REQUIRE_VERIFIED_PHONE_SENSITIVE=false

# Authentication Methods
AUTH_ALLOW_PASSWORD=true
AUTH_ALLOW_GOOGLE=true
AUTH_ALLOW_MICROSOFT=true
AUTH_ALLOW_WEBAUTHN=true
AUTH_ALLOW_PASSKEY=true
AUTH_ALLOW_SECURITY_KEY=true
MTNAD_LOGIN_URL=http://ugmuvayo01.mtn.co.ug:8545/auth/user

# MFA (TOTP)
AUTH_MFA_ENABLED=true
AUTH_MFA_ISSUER=Bulk Data Wholesale
AUTH_MFA_TOTP_WINDOW=1

# MFA Recovery Codes
AUTH_RECOVERY_CODES_ENABLED=true
AUTH_RECOVERY_CODES_COUNT=10
AUTH_RECOVERY_CODES_MIN_THRESHOLD=2
AUTH_RECOVERY_CODES_REQUIRE_REAUTH=true
AUTH_RECOVERY_CODES_MAX_ATTEMPTS=5
AUTH_RECOVERY_CODES_ATTEMPT_WINDOW_SECONDS=900
AUTH_RECOVERY_CODES_LOCK_SECONDS=900

# Risk Engine
AUTH_RISK_STEP_UP_THRESHOLD=4
AUTH_RISK_ENABLE_IP_VALIDATION=true
AUTH_RISK_ENABLE_DEVICE_TRACKING=true
AUTH_RISK_ENABLE_IMPOSSIBLE_TRAVEL=true
AUTH_RISK_ENABLE_TIME_ANALYSIS=true

# Session Management
AUTH_SESSION_TTL_SECONDS=86400
AUTH_SESSION_IDLE_TIMEOUT_SECONDS=1800
AUTH_SESSION_ROTATION_ENABLED=true

# Advanced Policy Controls
AUTH_DEVICE_TRUST_STRICT=true
AUTH_BLOCK_ON_RECOVERY_POLICY_VIOLATION=false
AUTH_FORCE_MFA_FOR_PRIVILEGED=true

# WebAuthn / Passkeys
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Bulk Data Wholesale
WEBAUTHN_ORIGIN=http://localhost:3000

