{{!-- src/modules/notifications/templates/digest.hbs --}}
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{period}} Digest</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background-color: #f5f5f5;
      margin: 0;
      padding: 0;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
      background-color: #ffffff;
    }
    .header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 30px;
      text-align: center;
    }
    .content {
      padding: 30px;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 15px;
      margin: 20px 0;
    }
    .stat-card {
      background: #f8f9fa;
      border-radius: 8px;
      padding: 20px;
      text-align: center;
    }
    .stat-number {
      font-size: 32px;
      font-weight: bold;
      color: #667eea;
    }
    .stat-label {
      font-size: 14px;
      color: #666;
      margin-top: 5px;
    }
    .video-card {
      border: 1px solid #e0e0e0;
      border-radius: 8px;
      overflow: hidden;
      margin-bottom: 15px;
    }
    .video-thumbnail {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }
    .video-info {
      padding: 15px;
    }
    .comment-card {
      background: #f8f9fa;
      border-left: 3px solid #667eea;
      padding: 15px;
      margin-bottom: 10px;
      border-radius: 4px;
    }
    .btn {
      display: inline-block;
      background: #667eea;
      color: white;
      padding: 12px 30px;
      text-decoration: none;
      border-radius: 6px;
      margin: 10px 0;
    }
    .footer {
      background: #f8f9fa;
      padding: 20px;
      text-align: center;
      font-size: 12px;
      color: #666;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Your {{period}} Digest</h1>
      <p>{{dateRange}}</p>
    </div>

    <div class="content">
      <p>Hi {{userName}},</p>
      
      {{#if hasActivity}}
        <p>Here's what happened while you were away:</p>

        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-number">{{stats.newVideos}}</div>
            <div class="stat-label">New Videos</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">{{stats.newComments}}</div>
            <div class="stat-label">New Comments</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">{{stats.newLikes}}</div>
            <div class="stat-label">New Likes</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">{{stats.unreadNotifications}}</div>
            <div class="stat-label">Notifications</div>
          </div>
        </div>

        {{#if hasNewVideos}}
          <h2>🎥 New Videos from Models You Follow</h2>
          {{#each newVideos}}
            <div class="video-card">
              <img src="{{thumbnail}}" alt="{{title}}" class="video-thumbnail">
              <div class="video-info">
                <h3>{{title}}</h3>
                <p><strong>{{modelName}}</strong></p>
                <p>👁️ {{views}} views · ❤️ {{likes}} likes</p>
                <a href="{{url}}" class="btn">Watch Now</a>
              </div>
            </div>
          {{/each}}
        {{/if}}

        {{#if hasComments}}
          <h2>💬 Recent Comments on Your Videos</h2>
          {{#each topComments}}
            <div class="comment-card">
              <p><strong>{{userName}}</strong> on "{{videoTitle}}"</p>
              <p>{{content}}</p>
              <small>{{createdAt}}</small>
            </div>
          {{/each}}
        {{/if}}

        <div style="text-align: center; margin-top: 30px;">
          <a href="{{notificationsUrl}}" class="btn">View All Notifications</a>
          <a href="{{dashboardUrl}}" class="btn">Go to Dashboard</a>
        </div>
      {{else}}
        <p>No new activity during this period. Check back later!</p>
        <div style="text-align: center; margin-top: 30px;">
          <a href="{{dashboardUrl}}" class="btn">Browse Videos</a>
        </div>
      {{/if}}
    </div>

    <div class="footer">
      <p>© {{year}} {{appName}}. All rights reserved.</p>
      <p>
        <a href="{{preferencesUrl}}">Email Preferences</a> | 
        <a href="#">Unsubscribe</a>
      </p>
    </div>
  </div>
</body>
</html>
