{{!-- src/shared/templates/email/invoice.hbs --}}
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Invoice {{invoiceNumber}}</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #0a0a0a;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #0a0a0a;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <table width="600" cellpadding="0" cellspacing="0" style="background-color: #1a1a1a; border-radius: 12px;">
          
          <!-- Header -->
          <tr>
            <td style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 40px 30px;">
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="vertical-align: top;">
                    <h1 style="margin: 0; color: #ffffff; font-size: 28px;">INVOICE</h1>
                    <p style="margin: 5px 0 0; color: #e0e0e0; font-size: 16px;">{{invoiceNumber}}</p>
                  </td>
                  <td style="text-align: right; vertical-align: top;">
                    <p style="margin: 0; color: #e0e0e0; font-size: 14px;">{{appName}}</p>
                    <p style="margin: 5px 0 0; color: #b0b0b0; font-size: 12px;">Invoice Date: {{date}}</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Invoice Details -->
          <tr>
            <td style="padding: 40px 30px;">
              
              <!-- Bill To Section -->
              <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 30px;">
                <tr>
                  <td>
                    <p style="margin: 0 0 5px; color: #888; font-size: 12px; text-transform: uppercase;">Bill To</p>
                    <p style="margin: 0; color: #fff; font-size: 16px; font-weight: 600;">{{userName}}</p>
                    {{#if userEmail}}
                    <p style="margin: 5px 0 0; color: #888; font-size: 14px;">{{userEmail}}</p>
                    {{/if}}
                  </td>
                  <td style="text-align: right;">
                    <p style="margin: 0 0 5px; color: #888; font-size: 12px; text-transform: uppercase;">Amount Due</p>
                    <p style="margin: 0; color: #38ef7d; font-size: 28px; font-weight: 700;">{{amount}} {{currency}}</p>
                  </td>
                </tr>
              </table>

              <!-- Items Table -->
              <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #2a2a2a; border-radius: 8px; overflow: hidden; margin-bottom: 30px;">
                <!-- Table Header -->
                <tr style="background-color: #333;">
                  <td style="padding: 15px 20px; color: #888; font-size: 12px; text-transform: uppercase; font-weight: 600; border-bottom: 1px solid #444;">
                    Description
                  </td>
                  <td style="padding: 15px 20px; color: #888; font-size: 12px; text-transform: uppercase; font-weight: 600; text-align: right; border-bottom: 1px solid #444;">
                    Amount
                  </td>
                </tr>

                <!-- Items -->
                {{#each items}}
                <tr>
                  <td style="padding: 15px 20px; color: #e0e0e0; font-size: 14px; border-bottom: 1px solid #333;">
                    {{this.description}}
                  </td>
                  <td style="padding: 15px 20px; color: #e0e0e0; font-size: 14px; text-align: right; border-bottom: 1px solid #333;">
                    {{this.amount}} {{../currency}}
                  </td>
                </tr>
                {{/each}}

                <!-- Subtotal -->
                {{#if subtotal}}
                <tr>
                  <td style="padding: 15px 20px; color: #888; font-size: 14px; text-align: right;">
                    Subtotal
                  </td>
                  <td style="padding: 15px 20px; color: #e0e0e0; font-size: 14px; font-weight: 600; text-align: right;">
                    {{subtotal}} {{currency}}
                  </td>
                </tr>
                {{/if}}

                <!-- Tax -->
                {{#if tax}}
                <tr>
                  <td style="padding: 15px 20px; color: #888; font-size: 14px; text-align: right;">
                    Tax
                  </td>
                  <td style="padding: 15px 20px; color: #e0e0e0; font-size: 14px; font-weight: 600; text-align: right;">
                    {{tax}} {{currency}}
                  </td>
                </tr>
                {{/if}}

                <!-- Total -->
                <tr style="background-color: #333;">
                  <td style="padding: 20px; color: #fff; font-size: 16px; font-weight: 600; text-align: right;">
                    Total
                  </td>
                  <td style="padding: 20px; color: #38ef7d; font-size: 18px; font-weight: 700; text-align: right;">
                    {{amount}} {{currency}}
                  </td>
                </tr>
              </table>

              <!-- Payment Info -->
              <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #2a2a2a; border-left: 4px solid #38ef7d; border-radius: 8px; margin-bottom: 30px;">
                <tr>
                  <td style="padding: 20px;">
                    <p style="margin: 0 0 10px; color: #38ef7d; font-size: 14px; font-weight: 600; text-transform: uppercase;">
                      Payment Status
                    </p>
                    <p style="margin: 0; color: #b0b0b0; font-size: 14px; line-height: 1.6;">
                      {{#if isPaid}}
                        ✓ Payment received on {{paidDate}}
                      {{else}}
                        Payment is being processed
                      {{/if}}
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Download PDF Button -->
              {{#if pdfUrl}}
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="center">
                    <a href="{{pdfUrl}}" style="display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #ffffff; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 16px;">
                      Download PDF Invoice
                    </a>
                  </td>
                </tr>
              </table>
              {{/if}}

              <!-- Notes Section -->
              {{#if notes}}
              <table width="100%" cellpadding="0" cellspacing="0" style="margin-top: 30px;">
                <tr>
                  <td>
                    <p style="margin: 0 0 10px; color: #888; font-size: 12px; text-transform: uppercase;">Notes</p>
                    <p style="margin: 0; color: #b0b0b0; font-size: 14px; line-height: 1.6;">{{notes}}</p>
                  </td>
                </tr>
              </table>
              {{/if}}
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color: #0f0f0f; padding: 30px; text-align: center; border-top: 1px solid #2a2a2a;">
              <p style="margin: 0 0 10px; color: #888; font-size: 14px;">
                Thank you for your business!
              </p>
              <p style="margin: 0 0 15px; color: #666; font-size: 12px;">
                © {{year}} {{appName}}. All rights reserved.
              </p>
              <p style="margin: 0; color: #666; font-size: 12px;">
                <a href="{{baseUrl}}/account/billing" style="color: #667eea; text-decoration: none;">View Billing History</a> • 
                <a href="{{baseUrl}}/support" style="color: #667eea; text-decoration: none;">Contact Support</a>
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
