{{!-- src/shared/templates/email/content-rejected.hbs --}}
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Content Rejected</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #0a0a0a;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #0a0a0a;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <table width="600" cellpadding="0" cellspacing="0" style="background-color: #1a1a1a; border-radius: 12px;">
          
          <!-- Error Header -->
          <tr>
            <td style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); padding: 40px 30px; text-align: center;">
              <div style="font-size: 48px; margin-bottom: 10px;">❌</div>
              <h1 style="margin: 0; color: #ffffff; font-size: 28px;">Content Not Approved</h1>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 40px 30px;">
              <p style="margin: 0 0 20px; color: #e0e0e0; font-size: 16px; line-height: 1.6;">
                Hi {{userName}},
              </p>

              <p style="margin: 0 0 20px; color: #e0e0e0; font-size: 16px; line-height: 1.6;">
                Unfortunately, your {{contentType}} did not meet our community guidelines and cannot be published at this time.
              </p>

              <!-- Content Info -->
              <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #2a2a2a; border-radius: 8px; margin: 20px 0;">
                <tr>
                  <td style="padding: 20px;">
                    <p style="margin: 0 0 5px; color: #888; font-size: 12px; text-transform: uppercase;">{{contentType}} Title</p>
                    <p style="margin: 0; color: #fff; font-size: 16px; font-weight: 600;">{{contentTitle}}</p>
                  </td>
                </tr>
              </table>

              <!-- Rejection Reason -->
              {{#if rejectionReason}}
              <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #2a2a2a; border-left: 4px solid #f5576c; border-radius: 8px; margin: 20px 0;">
                <tr>
                  <td style="padding: 20px;">
                    <p style="margin: 0 0 10px; color: #f5576c; font-size: 14px; font-weight: 600; text-transform: uppercase;">
                      Reason for Rejection
                    </p>
                    <p style="margin: 0; color: #b0b0b0; font-size: 14px; line-height: 1.6;">
                      {{rejectionReason}}
                    </p>
                  </td>
                </tr>
              </table>
              {{/if}}

              <p style="margin: 0 0 30px; color: #b0b0b0; font-size: 15px;">
                Please review our community guidelines and feel free to resubmit your content after making the necessary changes.
              </p>

              {{#if actionUrl}}
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="center">
                    <a href="{{actionUrl}}" style="display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #ffffff; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 16px;">
                      View Guidelines
                    </a>
                  </td>
                </tr>
              </table>
              {{/if}}
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color: #0f0f0f; padding: 30px; text-align: center; border-top: 1px solid #2a2a2a;">
              <p style="margin: 0; color: #888; font-size: 14px;">
                © {{year}} {{appName}}. All rights reserved.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
