<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>New Video from {{modelName}}</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #0a0a0a;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #0a0a0a;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <table width="600" cellpadding="0" cellspacing="0" style="background-color: #1a1a1a; border-radius: 12px;">
          
          <!-- Header -->
          <tr>
            <td style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 40px 30px; text-align: center;">
              <div style="font-size: 48px; margin-bottom: 10px;">🎬</div>
              <h1 style="margin: 0; color: #ffffff; font-size: 28px;">New Video Available!</h1>
            </td>
          </tr>

          <!-- Video Thumbnail -->
          {{#if videoThumbnail}}
          <tr>
            <td style="padding: 0;">
              <img src="{{videoThumbnail}}" alt="{{videoTitle}}" style="width: 100%; height: auto; display: block;">
            </td>
          </tr>
          {{/if}}

          <!-- Content -->
          <tr>
            <td style="padding: 40px 30px;">
              <h2 style="margin: 0 0 10px; color: #fff; font-size: 22px;">{{videoTitle}}</h2>
              <p style="margin: 0 0 20px; color: #888; font-size: 14px;">by {{modelName}}</p>

              <p style="margin: 0 0 30px; color: #e0e0e0; font-size: 16px; line-height: 1.6;">
                {{message}}
              </p>

              {{#if actionUrl}}
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="center">
                    <a href="{{actionUrl}}" style="display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #ffffff; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 16px;">
                      Watch Now
                    </a>
                  </td>
                </tr>
              </table>
              {{/if}}
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color: #0f0f0f; padding: 30px; text-align: center; border-top: 1px solid #2a2a2a;">
              <p style="margin: 0 0 10px; color: #888; font-size: 14px;">
                © {{year}} {{appName}}. All rights reserved.
              </p>
              <p style="margin: 0; color: #666; font-size: 12px;">
                <a href="{{baseUrl}}/account/preferences" style="color: #667eea; text-decoration: none;">Notification Preferences</a>
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
